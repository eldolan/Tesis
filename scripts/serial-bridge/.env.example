# Configuración del serial bridge Arduino → n8n
# Copiar a .env y completar los valores reales:
#   cp .env.example .env

# Puerto serial del Arduino (USB)
# En Ubuntu suele ser /dev/ttyACM0 o /dev/ttyACM1
# Ver dispositivos conectados: ls /dev/ttyACM*
SERIAL_PORT=/dev/ttyACM0

# Velocidad de comunicación en baudios (debe coincidir con Serial.begin() del firmware)
SERIAL_BAUD=9600

# URL completa del webhook de n8n para ingesta de sensores (WF1)
# Formato local: http://localhost:5678/webhook/sensor-data
# Formato con Cloudflare Tunnel: https://n8n.mimichis.cl/webhook/sensor-data
N8N_WEBHOOK_URL=http://localhost:5678/webhook/sensor-data

# Clave de autenticación para el webhook de n8n
# Obtener del nodo de autenticación en WF1 dentro de la UI de n8n
# NO usar la clave de ejemplo en producción
SENSOR_API_KEY=cambiar-por-clave-real

# Segundos de espera inicial antes de reintentar conexión serial
# El bridge usa backoff exponencial: 5s → 10s → 20s → 40s → 60s (máximo)
RECONNECT_DELAY=5

# Nivel de logging: DEBUG | INFO | WARNING | ERROR
# Usar DEBUG para troubleshooting, INFO para operación normal
LOG_LEVEL=INFO
